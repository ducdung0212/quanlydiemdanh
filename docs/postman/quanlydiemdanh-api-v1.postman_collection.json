{
    "info": {
        "_postman_id": "2d47e7fd-1c72-4f1d-a6f4-4d818d7b1ce9",
        "name": "QuanLyDiemDanh API v1",
        "description": "Sample collection for all /api/v1 endpoints.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://127.0.0.1:8000/api/v1"
        },
        {
            "key": "access_token",
            "value": ""
        },
        {
            "key": "token_id",
            "value": "1"
        },
        {
            "key": "student_code",
            "value": "DH52100001"
        },
        {
            "key": "exam_schedule_id",
            "value": "1"
        },
        {
            "key": "attendance_record_id",
            "value": "1"
        }
    ],
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "const data = pm.response.json();",
                                    "if (data && data.access_token) {",
                                    "  pm.collectionVariables.set('access_token', data.access_token);",
                                    "}",
                                    "if (data && data.user && data.user.role) {",
                                    "  pm.collectionVariables.set('last_login_role', data.user.role);",
                                    "}",
                                    "if (data && data.user && data.user.student_code) {",
                                    "  pm.collectionVariables.set('student_code', data.user.student_code);",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "auth": {
                            "type": "noauth"
                        },
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"lecturer1@example.com\",\n  \"password\": \"12345678\",\n  \"device_name\": \"postman\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "login"
                            ]
                        },
                        "description": "Create Sanctum token. Saves access_token to collection variable."
                    }
                },
                {
                    "name": "Me",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{access_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/auth/me",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "me"
                            ]
                        }
                    }
                },
                {
                    "name": "Logout Current Token",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{access_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "url": {
                            "raw": "{{baseUrl}}/auth/logout",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "logout"
                            ]
                        }
                    }
                },
                {
                    "name": "Logout All Tokens",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{access_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "url": {
                            "raw": "{{baseUrl}}/auth/logout-all",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "logout-all"
                            ]
                        }
                    }
                },
                {
                    "name": "Revoke Token By ID",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{access_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "DELETE",
                        "url": {
                            "raw": "{{baseUrl}}/auth/tokens/{{token_id}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "tokens",
                                "{{token_id}}"
                            ]
                        }
                    }
                }
            ]
        },
